# ============================================================
# BackStroke environment configuration
# Copy to .env.local for dev. Set as Cloudflare secrets in prod.
# ============================================================

# --- Stripe Checkout ---
# Get the secret from https://dashboard.stripe.com/apikeys
# Create three Prices in https://dashboard.stripe.com/products and
# paste their price_xxx IDs below.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_FOUNDING=price_...   # one-time, $199
STRIPE_PRICE_MONTHLY=price_...    # recurring, $39/mo
STRIPE_PRICE_ANNUAL=price_...     # recurring, $399/yr

# Used for Stripe success_url / cancel_url redirects.
PUBLIC_SITE_URL=http://localhost:8080

# --- Supabase event store ---
# Project URL and anon key from your Supabase project settings.
# When unset, events still mirror to localStorage so the app works;
# they just don't reach the long-term ledger.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
